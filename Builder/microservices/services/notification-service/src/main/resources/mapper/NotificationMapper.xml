<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.projecthub.notification.repository.NotificationRepository">

    <resultMap id="NotificationMap" type="com.projecthub.notification.entity.Notification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="channel" property="channel"/>
        <result column="recipient" property="recipient"/>
        <result column="status" property="status"/>
        <result column="retry_count" property="retryCount"/>
        <result column="error_message" property="errorMessage"/>
        <result column="sent_at" property="sentAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="findByUserId" resultMap="NotificationMap">
        SELECT * FROM notifications
        WHERE user_id = #{userId} AND deleted = 0
        ORDER BY created_at DESC
    </select>

</mapper>
